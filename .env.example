# TinyVault configuration
# Copy to .env: cp .env.example .env
# This file is for your local environment only and is gitignored.

# Vault location (default: ~/.tvault)
# TVAULT_DIR=~/.tvault

# Passphrase for non-interactive unlock (CI/CD, scripts, MCP server).
# When set, tvault skips the interactive prompt.
# WARNING: do not commit this file. Do not put real passphrases in shared envs.
# TVAULT_PASSPHRASE=your-vault-passphrase
